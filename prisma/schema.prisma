// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  files     File[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model File {
  id          String   @id @default(uuid())
  name        String
  size        BigInt
  mimeType    String
  hash        String
  path        String   // Storage path (e.g., "account-id/assets/image.png")
  status      String   @default("PENDING") // PENDING, VERIFIED, FAILED
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([hash])
}

model FileFolder {
  id         String          @id @default(uuid())
  name       String
  path       String
  type       String
  owner      String
  size       BigInt          @default(0)
  details    Json            @default("{}")
  created_on DateTime        @default(now())
  updated_on DateTime        @updatedAt
  logs       FileFolderLog[]

  @@index([owner])
  @@index([path])
  @@map("filefolder")
}

model FileFolderLog {
  id            String     @id @default(uuid())
  filefolder_id String
  action        String
  details       Json       @default("{}")
  done_by       String
  done_on       DateTime   @default(now())
  filefolder    FileFolder @relation(fields: [filefolder_id], references: [id], onDelete: Cascade)

  @@index([filefolder_id])
  @@index([done_by])
  @@map("filefolder_log")
}

model ErrorLog {
  id          String   @id @default(uuid())
  on_page     String   // Page/Component where error occurred
  context     String   // JSON string of error details
  created_on  DateTime @default(now())
}

model WebDisk {
  id          String   @id @default(uuid())
  filename    String
  path        String
  mimeType    String   @default("application/octet-stream")
  uploaded_by String
  uploaded_on DateTime @default(now())
}

model Account {
  id            String   @id @default(uuid())
  account_type  String
  connection_id String?
  display_name  String?
  display_image String?
  neupid        String?
  created_on    DateTime @default(now())
  accessed_on   DateTime?
  role_id       String?
}

model SigninSession {
  id         String   @id @default(uuid())
  aid        String
  sid        String
  skey       String
  accountId  String?
  expires_at DateTime?
  created_at DateTime @default(now())

  @@index([aid, sid, skey])
}
